# =============================================================================
# AI TradeBot - .gitignore
# =============================================================================

# 环境变量 (重要!)
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# 虚拟环境
venv/
ENV/
env/
.venv/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# 数据文件
*.db
*.sqlite
*.sqlite3
data/
logs/
temp/

# 测试
.pytest_cache/
.coverage
htmlcov/

# 系统文件
.DS_Store
Thumbs.db
nul

# Git
.git/

# 敏感文件
secrets/
*.pem
*.key
credentials.json
