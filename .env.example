# =============================================================================
# AI TradeBot - 环境变量配置模板
# =============================================================================
# 使用说明：
# 1. 复制此文件为 .env
# 2. 填写你的实际配置值
# 3. .env 文件已加入 .gitignore，不会提交到代码仓库
# =============================================================================

# =============================================================================
# 基础配置
# =============================================================================
PROJECT_NAME=AI_TradeBot
VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
TIMEZONE=Asia/Shanghai

# =============================================================================
# 数据库配置 (SQLite)
# =============================================================================
DATABASE_URL=sqlite:///./data/database/aitradebot.db
DATABASE_ECHO=false

# =============================================================================
# FastAPI 配置
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
CORS_ORIGINS=["http://localhost:8501", "http://localhost:3000"]

# WebSocket 配置
WS_MESSAGE_QUEUE_SIZE=1000

# =============================================================================
# AI Matrix API Keys
# =============================================================================

# --- Kimi (Moonshot AI) ---
KIMI_API_KEY=your_kimi_api_key_here
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-128k
KIMI_MAX_TOKENS=16000
KIMI_TEMPERATURE=0.3

# --- 智谱 GLM-4 ---
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4
ZHIPU_MAX_TOKENS=8000
ZHIPU_TEMPERATURE=0.5

# --- MiniMax ---
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_GROUP_ID=your_minimax_group_id_here
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=abab6.5s-chat
MINIMAX_MAX_TOKENS=4000
MINIMAX_TEMPERATURE=0.7

# --- Tavily (搜索 + AI) ---
TAVILY_API_KEY=your_tavily_api_key_here
TAVILY_BASE_URL=https://api.tavily.com
TAVILY_MAX_RESULTS=10
TAVILY_SEARCH_DEPTH=basic
TAVILY_INCLUDE_DOMAINS=[]
TAVILY_EXCLUDE_DOMAINS=[]

# =============================================================================
# 数据源 API Keys
# =============================================================================

# --- Tushare (历史行情、基本面) ---
TUSHARE_TOKEN=your_tushare_token_here
TUSHARE_BASE_URL=http://api.tushare.pro
TUSHARE_MAX_RETRIES=3
TUSHARE_TIMEOUT=30

# --- AkShare (实时行情) ---
AKSHARE_ENABLED=true
AKSHARE_TIMEOUT=10

# =============================================================================
# 执行层配置 (QMT/xtquant)
# =============================================================================
QMT_ENABLED=false
QMT_PATH=C:\QMT\userdata_mini
QMT_BROKER_ID=your_broker_id
QMT_ACCOUNT_ID=your_account_id
QMT_PASSWORD=your_qmt_password
QMT_TRADING_HOST=127.0.0.1
QMT_TRADING_PORT=11111
QMT_SESSION_ID=123456

# 模拟交易模式（设置为 true 时不实际下单）
SIMULATION_MODE=true
SIMULATION_INITIAL_CAPITAL=1000000

# =============================================================================
# OpenClaw 爬虫配置 (Playwright)
# =============================================================================
OPENCLAW_HEADLESS=true
OPENCLAW_TIMEOUT=30000
OPENCLAW_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# 浏览器配置
PLAYWRIGHT_BROWSER_TYPE=chromium
PLAYWRIGHT_SLOW_MO=0
PLAYWRIGHT_DEVTOOLS=false

# 代理配置（可选）
HTTP_PROXY=
HTTPS_PROXY=

# =============================================================================
# 风控配置 (Safety Locks)
# =============================================================================
# 单只股票最大仓位比例 (0.10 = 10%)
MAX_SINGLE_POSITION_RATIO=0.10

# 单日最大亏损比例 (0.03 = 3%)
MAX_DAILY_LOSS_RATIO=0.03

# 单周最大亏损比例 (0.05 = 5%)
MAX_WEEKLY_LOSS_RATIO=0.05

# 单日最大交易次数
MAX_TRADES_PER_DAY=10

# 最低账户余额要求
MIN_ACCOUNT_BALANCE=50000

# 熔断后冷却时长（小时）
CIRCUIT_BREAK_COOLDOWN_HOURS=24

# 交易时段控制
TRADING_START_TIME=09:30
TRADING_END_TIME=15:00
ALLOW_PRE_MARKET=false
ALLOW_AFTER_MARKET=false

# =============================================================================
# 决策引擎配置
# =============================================================================
DECISION_CONFIDENCE_THRESHOLD=0.6
DECISION_MAX_CONCURRENT=5

# 退出规划器配置
EXIT_PLAN_TAKE_PROFIT_METHOD=logic_based
EXIT_PLAN_STOP_LOSS_METHOD=falsification_based
EXIT_PLAN_EXPIRATION_METHOD=event_window

# 最小持仓时间（秒），避免频繁交易
MIN_HOLDING_TIME_SECONDS=60

# =============================================================================
# Streamlit UI 配置
# =============================================================================
STREAMLIT_TITLE=AI TradeBot Dashboard
STREAMLIT_PORT=8501
STREAMLIT_THEME=light

# =============================================================================
# 日志配置
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_FILE_PATH=logs/aitradebot.log
LOG_ROTATION=10 MB
LOG_RETENTION=30 days

# =============================================================================
# 缓存配置
# =============================================================================
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE=1000

# Redis 配置（可选，用于生产环境分布式部署）
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# =============================================================================
# 监控与告警
# =============================================================================
MONITORING_ENABLED=true

# 钉钉告警（可选）
DINGTALK_WEBHOOK=
DINGTALK_ENABLED=false

# 邮件告警（可选）
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=

# =============================================================================
# 事件总线配置
# =============================================================================
EVENT_BUS_TYPE=memory
EVENT_QUEUE_MAX_SIZE=10000
EVENT_PROCESSOR_WORKERS=4

# =============================================================================
# 回测配置
# =============================================================================
BACKTEST_START_DATE=2024-01-01
BACKTEST_END_DATE=2024-12-31
BACKTEST_INITIAL_CAPITAL=1000000
BACKTEST_COMMISSION=0.0003
BACKTEST_SLIPPAGE=0.001

# =============================================================================
# 其他配置
# =============================================================================
# 时区数据源
TIMEZONE_DB_PATH=data/cache/zoneinfo

# 数据导出目录
DATA_EXPORT_PATH=data/exports

# 临时文件目录
TEMP_PATH=data/temp

# =============================================================================
# 开发与调试
# =============================================================================
# 是否启用性能分析
PROFILING_ENABLED=false

# 是否记录所有 AI 请求/响应
LOG_ALL_AI_CALLS=true

# 是否启用请求限流
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# =============================================================================
# 生产环境注意事项
# =============================================================================
# 1. 确保 DEBUG=false
# 2. 设置强密码和安全的 API Key
# 3. 启用 HTTPS
# 4. 配置防火墙规则
# 5. 定期备份数据库
# 6. 启用日志轮转和远程日志
# 7. 配置监控告警
# 8. 确保 SIMULATION_MODE=false (仅确认无误后)
# =============================================================================
